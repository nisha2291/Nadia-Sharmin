<section class="product-grid">
  <div class="page-width">
    
    <h2 class="grid-heading">
      {{ section.settings.heading }}
    </h2>

    <div class="grid-container">
      {% for block in section.blocks %}
        {% assign product = block.settings.product %}

        {% if product != blank %}
          <div class="grid-item" data-product-id="{{ product.id }}">

            <img 
              src="{{ product.featured_image | image_url: width: 600 }}" 
              alt="{{ product.title }}"
            >

            <button 
              class="grid-plus" 
              data-handle="{{ product.handle }}"
            >
              +
            </button>

          </div>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</section>

<style>
.product-grid {
  padding: 80px 40px;
}

.grid-heading {
  font-size: 28px;
  margin-bottom: 40px;
}

.grid-container {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

.grid-item {
  position: relative;
  overflow: hidden;
}

.grid-item img {
  width: 100%;
  display: block;
}

.grid-plus {
  position: absolute;
  top: 12px;
  right: 12px;
  width: 30px;
  height: 30px;
  border-radius: 50%;
  background: white;
  border: none;
  cursor: pointer;
  font-size: 18px;
}

.grid-plus:hover {
  background: black;
  color: white;
}

/* Mobile */
@media (max-width: 768px) {
  .grid-container {
    grid-template-columns: 1fr;
  }
}
</style>

{% schema %}
{
  "name": "Custom Product Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tisso vision in the wild"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select product"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Custom Product Grid"
    }
  ]
}
{% endschema %}

<section id="custom-grid-{{ section.id }}" class="custom-grid-section">
  <div class="custom-grid page-width">
    <h2 class="custom-grid__heading">{{ section.settings.heading }}</h2>

    <div class="custom-grid__items">
      {% for block in section.blocks %}
        {% assign product = block.settings.product %}
        {% if product != blank %}
          <article
            class="custom-grid__item"
            {{ block.shopify_attributes }}
            data-product-handle="{{ product.handle }}"
            data-block-id="{{ block.id }}"
          >
            <div class="custom-grid__image-wrap">
              <img
                class="custom-grid__image"
                src="{{ product.featured_image | image_url: width: 900 }}"
                alt="{{ product.title | escape }}"
                loading="lazy"
                width="450"
                height="540"
              >

              <button
                class="custom-grid__plus"
                type="button"
                aria-label="Open {{ product.title | escape }}"
                data-open-popup
                data-product-handle="{{ product.handle }}"
              >
                +
              </button>
            </div>

            <script type="application/json" class="product-json">
              {{ product | json }}
            </script>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="product-popup" data-popup hidden>
    <div class="product-popup__overlay" data-close-popup></div>

    <div class="product-popup__dialog" role="dialog" aria-modal="true" aria-label="Product popup">
      <button class="product-popup__close" type="button" data-close-popup>×</button>

      <div class="product-popup__top">
        <div class="product-popup__image-wrap">
          <img class="product-popup__image" src="" alt="">
        </div>

        <div class="product-popup__info">
          <h3 class="product-popup__title"></h3>
          <div class="product-popup__price"></div>
          <div class="product-popup__desc"></div>
        </div>
      </div>

      <div class="product-popup__options" data-options></div>

      <button class="product-popup__add" type="button" data-add-to-cart>
        <span>ADD TO CART</span>
        <span class="product-popup__arrow">→</span>
      </button>

      <div class="product-popup__message" data-popup-message></div>
    </div>
  </div>
</section>

<style>
  .custom-grid-section {
    background: #efefef;
    padding: 72px 0 96px;
  }

  .custom-grid__heading {
    font-size: 64px;
    line-height: 1.05;
    margin: 0 0 36px;
    color: #111;
    font-weight: 500;
  }

  .custom-grid__items {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }

  .custom-grid__item {
    position: relative;
  }

  .custom-grid__image-wrap {
    position: relative;
    background: #ddd;
    overflow: hidden;
  }

  .custom-grid__image {
    display: block;
    width: 100%;
    aspect-ratio: 0.85;
    object-fit: cover;
  }

  .custom-grid__plus {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: none;
    background: #fff;
    color: #111;
    font-size: 24px;
    line-height: 1;
    cursor: pointer;
    box-shadow: 0 4px 20px rgba(0,0,0,.12);
    transition: transform 0.2s ease;
  }

  .custom-grid__plus:hover {
    transform: translateY(-50%) scale(1.08);
  }

  .product-popup[hidden] {
    display: none;
  }

  .product-popup {
    position: fixed;
    inset: 0;
    z-index: 60;
  }

  .product-popup__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,.24);
  }

  .product-popup__dialog {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: min(92vw, 430px);
    background: #fff;
    padding: 18px;
    box-shadow: 0 20px 50px rgba(0,0,0,.18);
  }

  .product-popup__close {
    position: absolute;
    right: 12px;
    top: 8px;
    border: none;
    background: transparent;
    font-size: 32px;
    cursor: pointer;
    color: #111;
  }

  .product-popup__top {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 18px;
    margin-bottom: 20px;
  }

  .product-popup__image {
    width: 100%;
    aspect-ratio: 0.8;
    object-fit: cover;
    display: block;
  }

  .product-popup__title {
    margin: 0 0 10px;
    font-size: 28px;
    line-height: 1.1;
    color: #111;
  }

  .product-popup__price {
    margin-bottom: 10px;
    font-size: 18px;
    color: #111;
  }

  .product-popup__desc {
    font-size: 15px;
    line-height: 1.45;
    color: #333;
  }

  .popup-option {
    margin-bottom: 16px;
  }

  .popup-option__label {
    display: block;
    margin-bottom: 8px;
    font-size: 14px;
    color: #111;
  }

  .popup-option__values {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
  }

  .popup-option__button {
    border: 1px solid #111;
    background: #fff;
    color: #111;
    min-width: 86px;
    min-height: 44px;
    padding: 8px 14px;
    cursor: pointer;
    font-size: 15px;
  }

  .popup-option__button.is-active {
    background: #111;
    color: #fff;
  }

  .popup-option__select {
    width: 100%;
    min-height: 48px;
    border: 1px solid #111;
    padding: 0 14px;
    font-size: 15px;
    background: #fff;
  }

  .product-popup__add {
    width: 100%;
    min-height: 56px;
    border: none;
    background: #000;
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    cursor: pointer;
    font-size: 16px;
    margin-top: 10px;
    transition: opacity 0.2s ease;
  }

  .product-popup__add:hover .product-popup__arrow {
    transform: translateX(6px);
  }

  .product-popup__arrow {
    display: inline-block;
    transition: transform 0.25s ease;
  }

  .product-popup__message {
    margin-top: 12px;
    font-size: 14px;
    color: #111;
  }

  @media screen and (max-width: 989px) {
    .custom-grid__heading {
      font-size: 44px;
    }

    .custom-grid__items {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .custom-grid-section {
      padding: 48px 0 64px;
    }

    .custom-grid__heading {
      font-size: 34px;
      margin-bottom: 22px;
    }

    .custom-grid__items {
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .product-popup__top {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  (() => {
    const sectionRoot = document.getElementById('custom-grid-{{ section.id }}');
    if (!sectionRoot) return;

    const popup = sectionRoot.querySelector('[data-popup]');
    const popupImage = popup.querySelector('.product-popup__image');
    const popupTitle = popup.querySelector('.product-popup__title');
    const popupPrice = popup.querySelector('.product-popup__price');
    const popupDesc = popup.querySelector('.product-popup__desc');
    const optionsWrap = popup.querySelector('[data-options]');
    const addBtn = popup.querySelector('[data-add-to-cart]');
    const messageBox = popup.querySelector('[data-popup-message]');

    const bonusProductHandle = {{ section.settings.bonus_product.handle | json }};
    let currentProduct = null;
    let selectedOptions = {};

    function moneyFormat(cents) {
      return (cents / 100).toLocaleString(undefined, {
        style: 'currency',
        currency: '{{ cart.currency.iso_code }}'
      });
    }

    function getVariantFromOptions(product, chosen) {
      return product.variants.find((variant) => {
        return variant.options.every((opt, index) => {
          return opt === chosen['option' + (index + 1)];
        });
      });
    }

    function setDefaultOptions(product) {
      selectedOptions = {};
      product.options.forEach((optionName, index) => {
        const value = product.variants[0]?.options[index];
        selectedOptions['option' + (index + 1)] = value;
      });
    }

    function renderOptions(product) {
      optionsWrap.innerHTML = '';

      product.options_with_values.forEach((option, index) => {
        const optionIndex = index + 1;
        const wrapper = document.createElement('div');
        wrapper.className = 'popup-option';

        const label = document.createElement('label');
        label.className = 'popup-option__label';
        label.textContent = option.name;
        wrapper.appendChild(label);

        if (option.name.toLowerCase() === 'size') {
          const select = document.createElement('select');
          select.className = 'popup-option__select';
          select.dataset.optionKey = 'option' + optionIndex;

          option.values.forEach((value) => {
            const opt = document.createElement('option');
            opt.value = value;
            opt.textContent = value;
            if (selectedOptions['option' + optionIndex] === value) opt.selected = true;
            select.appendChild(opt);
          });

          select.addEventListener('change', (e) => {
            selectedOptions[e.target.dataset.optionKey] = e.target.value;
          });

          wrapper.appendChild(select);
        } else {
          const valuesWrap = document.createElement('div');
          valuesWrap.className = 'popup-option__values';

          option.values.forEach((value) => {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'popup-option__button';
            btn.dataset.optionKey = 'option' + optionIndex;
            btn.dataset.value = value;
            btn.textContent = value;

            if (selectedOptions['option' + optionIndex] === value) {
              btn.classList.add('is-active');
            }

            btn.addEventListener('click', () => {
              selectedOptions[btn.dataset.optionKey] = btn.dataset.value;

              valuesWrap.querySelectorAll('.popup-option__button').forEach((item) => {
                item.classList.remove('is-active');
              });

              btn.classList.add('is-active');
            });

            valuesWrap.appendChild(btn);
          });

          wrapper.appendChild(valuesWrap);
        }

        optionsWrap.appendChild(wrapper);
      });
    }

    function openPopup(product) {
      currentProduct = product;
      setDefaultOptions(product);

      popupImage.src = product.featured_image;
      popupImage.alt = product.title;
      popupTitle.textContent = product.title;
      popupPrice.textContent = moneyFormat(product.price);
      popupDesc.innerHTML = product.description || '';
      messageBox.textContent = '';

      renderOptions(product);
      popup.hidden = false;
      document.body.style.overflow = 'hidden';
    }

    function closePopup() {
      popup.hidden = true;
      document.body.style.overflow = '';
      currentProduct = null;
    }

    async function addBonusProductIfNeeded() {
      if (!bonusProductHandle) return;

      const hasBlack = Object.values(selectedOptions).includes('Black');
      const hasMedium = Object.values(selectedOptions).includes('Medium');

      if (!(hasBlack && hasMedium)) return;

      const res = await fetch('/products/' + bonusProductHandle + '.js');
      const bonusProduct = await res.json();
      const bonusVariant = bonusProduct.variants.find(v => v.available) || bonusProduct.variants[0];

      if (!bonusVariant) return;

      await fetch('/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify({
          id: bonusVariant.id,
          quantity: 1
        })
      });
    }

    async function addCurrentProductToCart() {
      if (!currentProduct) return;

      const variant = getVariantFromOptions(currentProduct, selectedOptions);

      if (!variant) {
        messageBox.textContent = 'Please select valid options.';
        return;
      }

      addBtn.disabled = true;
      messageBox.textContent = 'Adding to cart...';

      try {
        await fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify({
            id: variant.id,
            quantity: 1
          })
        });

        await addBonusProductIfNeeded();

        messageBox.textContent = 'Added to cart successfully.';
        setTimeout(() => {
          window.location.href = '/cart';
        }, 600);
      } catch (error) {
        messageBox.textContent = 'Something went wrong. Please try again.';
      } finally {
        addBtn.disabled = false;
      }
    }

    sectionRoot.querySelectorAll('.custom-grid__item').forEach((card) => {
      const json = card.querySelector('.product-json');
      if (!json) return;

      const productData = JSON.parse(json.textContent);
      const openBtn = card.querySelector('[data-open-popup]');

      openBtn.addEventListener('click', () => openPopup(productData));
    });

    popup.querySelectorAll('[data-close-popup]').forEach((el) => {
      el.addEventListener('click', closePopup);
    });

    addBtn.addEventListener('click', addCurrentProductToCart);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !popup.hidden) closePopup();
    });
  })();
</script>

{% schema %}
{
  "name": "Custom Product Grid",
  "tag": "section",
  "class": "section-custom-product-grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tisso vision in the wild"
    },
    {
      "type": "product",
      "id": "bonus_product",
      "label": "Bonus product for Black + Medium rule"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select product"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Custom Product Grid",
      "blocks": [
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" }
      ]
    }
  ]
}
{% endschema %}
{{ 'custom-product-grid.css' | asset_url | stylesheet_tag }}

<section class="cpg-section" id="cpg-{{ section.id }}">
  <div class="cpg-container">

    {% if section.settings.heading != blank %}
      <h2 class="cpg-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="cpg-grid">
      {% for block in section.blocks %}
        {% assign product = block.settings.product %}
        {% if product != blank %}
          <div class="cpg-card" {{ block.shopify_attributes }}>

            <div class="cpg-card__image-wrap">
              {% if product.featured_image %}
                <img
                  class="cpg-card__image"
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  loading="lazy"
                  width="600"
                  height="{{ 600 | divided_by: product.featured_image.aspect_ratio | round }}"
                >
              {% else %}
                <div class="cpg-card__no-image">{{ 'image' | placeholder_svg_tag: 'cpg-placeholder-svg' }}</div>
              {% endif %}

              <button
                class="cpg-card__quick-view"
                data-product-handle="{{ product.handle }}"
                data-product-url="{{ product.url }}"
                aria-label="Quick view {{ product.title | escape }}"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                Quick View
              </button>
            </div>

            <div class="cpg-card__info">
              <p class="cpg-card__title">{{ product.title }}</p>
              <p class="cpg-card__price">{{ product.price | money }}</p>
            </div>

          </div>
        {% else %}
          <div class="cpg-card cpg-card--empty" {{ block.shopify_attributes }}>
            <div class="cpg-card__image-wrap">
              {{ 'product-1' | placeholder_svg_tag: 'cpg-placeholder-svg' }}
            </div>
            <div class="cpg-card__info">
              <p class="cpg-card__title">Select a product</p>
            </div>
          </div>
        {% endif %}
      {% endfor %}

      {% if section.blocks.size == 0 %}
        {% for i in (1..6) %}
          <div class="cpg-card cpg-card--empty">
            <div class="cpg-card__image-wrap">
              {{ 'product-' | append: i | placeholder_svg_tag: 'cpg-placeholder-svg' }}
            </div>
            <div class="cpg-card__info">
              <p class="cpg-card__title">Add a product block</p>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>

  </div>
</section>

<!-- Quick View Modal -->
<div class="cpg-modal" id="cpg-modal" role="dialog" aria-modal="true" aria-label="Quick view" hidden>
  <div class="cpg-modal__backdrop" id="cpg-modal-backdrop"></div>
  <div class="cpg-modal__panel">
    <button class="cpg-modal__close" id="cpg-modal-close" aria-label="Close">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <div class="cpg-modal__body" id="cpg-modal-body">
      <div class="cpg-modal__loading">
        <div class="cpg-spinner"></div>
      </div>
    </div>
  </div>
</div>

<style>
/* ── Section Layout ────────────────────────────────────────── */
.cpg-section {
  padding: 60px 0;
}
.cpg-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 20px;
}
.cpg-heading {
  font-size: clamp(1.5rem, 3vw, 2.2rem);
  font-weight: 600;
  margin-bottom: 32px;
  letter-spacing: -0.02em;
}

/* ── Grid ──────────────────────────────────────────────────── */
.cpg-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}
@media (max-width: 768px) {
  .cpg-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 480px) {
  .cpg-grid { grid-template-columns: 1fr; }
}

/* ── Card ──────────────────────────────────────────────────── */
.cpg-card {
  position: relative;
  overflow: hidden;
  border-radius: 4px;
  background: #f5f5f5;
  cursor: pointer;
}
.cpg-card--empty {
  opacity: 0.5;
  cursor: default;
}
.cpg-card__image-wrap {
  position: relative;
  aspect-ratio: 4 / 5;
  overflow: hidden;
}
.cpg-card__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.5s ease;
}
.cpg-card:hover .cpg-card__image {
  transform: scale(1.04);
}
.cpg-placeholder-svg {
  width: 100%;
  height: 100%;
  background: #e8e8e8;
}

/* ── Quick View Button ─────────────────────────────────────── */
.cpg-card__quick-view {
  position: absolute;
  bottom: 12px;
  left: 50%;
  transform: translateX(-50%) translateY(8px);
  opacity: 0;
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 10px 18px;
  background: rgba(255, 255, 255, 0.95);
  border: none;
  border-radius: 2px;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.04em;
  cursor: pointer;
  transition: opacity 0.25s ease, transform 0.25s ease;
  white-space: nowrap;
}
.cpg-card:hover .cpg-card__quick-view {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}
.cpg-card__quick-view:hover {
  background: #fff;
}

/* ── Card Info ─────────────────────────────────────────────── */
.cpg-card__info {
  padding: 10px 4px 4px;
}
.cpg-card__title {
  font-size: 14px;
  margin: 0 0 4px;
  font-weight: 500;
}
.cpg-card__price {
  font-size: 13px;
  margin: 0;
  color: #555;
}

/* ── Modal ─────────────────────────────────────────────────── */
.cpg-modal {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cpg-modal[hidden] { display: none; }

.cpg-modal__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.55);
  cursor: pointer;
}
.cpg-modal__panel {
  position: relative;
  background: #fff;
  border-radius: 6px;
  width: min(900px, 95vw);
  max-height: 90vh;
  overflow-y: auto;
  padding: 32px;
  z-index: 1;
  animation: cpg-slide-up 0.3s ease;
}
@keyframes cpg-slide-up {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0); }
}
.cpg-modal__close {
  position: absolute;
  top: 14px;
  right: 14px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 6px;
  line-height: 0;
  color: #333;
}
.cpg-modal__close:hover { color: #000; }

/* ── Modal Body Layout ─────────────────────────────────────── */
.cpg-modal__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32px;
}
@media (max-width: 640px) {
  .cpg-modal__inner { grid-template-columns: 1fr; }
  .cpg-modal__panel { padding: 20px; }
}
.cpg-modal__img {
  width: 100%;
  aspect-ratio: 1;
  object-fit: cover;
  border-radius: 4px;
}
.cpg-modal__product-title {
  font-size: 1.4rem;
  font-weight: 600;
  margin: 0 0 10px;
}
.cpg-modal__product-price {
  font-size: 1.1rem;
  margin: 0 0 16px;
  color: #444;
}
.cpg-modal__description {
  font-size: 14px;
  line-height: 1.65;
  color: #555;
  margin: 0 0 20px;
}

/* Variant select */
.cpg-modal__variants {
  margin-bottom: 20px;
}
.cpg-modal__variants label {
  display: block;
  font-size: 13px;
  font-weight: 500;
  margin-bottom: 6px;
}
.cpg-modal__variants select {
  width: 100%;
  padding: 10px 12px;
  border: 1px solid #ddd;
  border-radius: 3px;
  font-size: 14px;
  background: #fff;
  cursor: pointer;
}

/* Add to cart button */
.cpg-modal__atc {
  width: 100%;
  padding: 14px;
  background: #111;
  color: #fff;
  border: none;
  border-radius: 3px;
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 0.06em;
  cursor: pointer;
  transition: background 0.2s;
  margin-bottom: 10px;
}
.cpg-modal__atc:hover { background: #333; }
.cpg-modal__atc:disabled { background: #999; cursor: not-allowed; }

.cpg-modal__view-link {
  display: block;
  text-align: center;
  font-size: 13px;
  color: #555;
  text-decoration: underline;
}

/* Loading */
.cpg-modal__loading {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 200px;
}
.cpg-spinner {
  width: 36px;
  height: 36px;
  border: 3px solid #eee;
  border-top-color: #333;
  border-radius: 50%;
  animation: cpg-spin 0.7s linear infinite;
}
@keyframes cpg-spin {
  to { transform: rotate(360deg); }
}

/* ATC feedback */
.cpg-toast {
  position: fixed;
  bottom: 24px;
  left: 50%;
  transform: translateX(-50%) translateY(80px);
  background: #111;
  color: #fff;
  padding: 12px 24px;
  border-radius: 4px;
  font-size: 14px;
  z-index: 99999;
  transition: transform 0.3s ease;
  pointer-events: none;
}
.cpg-toast.cpg-toast--show {
  transform: translateX(-50%) translateY(0);
}
</style>

<script>
(function () {
  'use strict';

  var modal       = document.getElementById('cpg-modal');
  var modalBody   = document.getElementById('cpg-modal-body');
  var modalClose  = document.getElementById('cpg-modal-close');
  var backdrop    = document.getElementById('cpg-modal-backdrop');
  var activeHandle = null;

  /* ── Open / Close ───────────────────────────────────────── */
  function openModal() {
    modal.removeAttribute('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.setAttribute('hidden', '');
    document.body.style.overflow = '';
    modalBody.innerHTML = '<div class="cpg-modal__loading"><div class="cpg-spinner"></div></div>';
    activeHandle = null;
  }

  modalClose.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeModal();
  });

  /* ── Fetch product JSON and render modal ────────────────── */
  function loadProduct(handle) {
    if (activeHandle === handle) return;
    activeHandle = handle;
    openModal();
    modalBody.innerHTML = '<div class="cpg-modal__loading"><div class="cpg-spinner"></div></div>';

    fetch('/products/' + handle + '.js')
      .then(function (r) { return r.json(); })
      .then(function (product) {
        renderModal(product);
      })
      .catch(function () {
        modalBody.innerHTML = '<p style="padding:24px">Failed to load product. <a href="/products/' + handle + '">View product page</a></p>';
      });
  }

  function renderModal(product) {
    var img = product.featured_image
      ? product.featured_image
      : (product.images && product.images[0] ? product.images[0] : null);

    var imgHtml = img
      ? '<img class="cpg-modal__img" src="' + img + '" alt="' + escapeHtml(product.title) + '" loading="lazy">'
      : '<div style="background:#eee;aspect-ratio:1;border-radius:4px;"></div>';

    var variantOptions = product.variants.map(function (v) {
      return '<option value="' + v.id + '" ' + (v.available ? '' : 'disabled') + '>' +
        escapeHtml(v.title) + (v.available ? '' : ' — Sold out') +
        '</option>';
    }).join('');

    var variantSelectHtml = product.variants.length > 1
      ? '<div class="cpg-modal__variants"><label>Options</label><select id="cpg-variant-select">' + variantOptions + '</select></div>'
      : '<input type="hidden" id="cpg-variant-select" value="' + product.variants[0].id + '">';

    var priceHtml = formatMoney(product.price_min);
    if (product.price_min !== product.price_max) {
      priceHtml += ' – ' + formatMoney(product.price_max);
    }

    var descHtml = product.description
      ? '<div class="cpg-modal__description">' + product.description.substring(0, 300) + (product.description.length > 300 ? '…' : '') + '</div>'
      : '';

    modalBody.innerHTML =
      '<div class="cpg-modal__inner">' +
        '<div>' + imgHtml + '</div>' +
        '<div>' +
          '<h2 class="cpg-modal__product-title">' + escapeHtml(product.title) + '</h2>' +
          '<p class="cpg-modal__product-price">' + priceHtml + '</p>' +
          descHtml +
          variantSelectHtml +
          '<button class="cpg-modal__atc" id="cpg-atc-btn">Add to Cart</button>' +
          '<a class="cpg-modal__view-link" href="/products/' + product.handle + '">View full details</a>' +
        '</div>' +
      '</div>';

    document.getElementById('cpg-atc-btn').addEventListener('click', function () {
      var variantEl = document.getElementById('cpg-variant-select');
      var variantId = variantEl ? variantEl.value : null;
      if (!variantId) return;
      addToCart(variantId, this);
    });
  }

  /* ── Add to Cart (Shopify AJAX API) ────────────────────── */
  function addToCart(variantId, btn) {
    btn.disabled = true;
    btn.textContent = 'Adding…';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    })
    .then(function (r) {
      if (!r.ok) throw new Error('Cart error');
      return r.json();
    })
    .then(function () {
      btn.textContent = '✓ Added';
      showToast('Item added to cart!');
      updateCartCount();
      setTimeout(function () {
        btn.disabled = false;
        btn.textContent = 'Add to Cart';
      }, 2000);
    })
    .catch(function () {
      btn.disabled = false;
      btn.textContent = 'Add to Cart';
      showToast('Could not add item. Please try again.');
    });
  }

  /* ── Update cart bubble count in header ──────────────────── */
  function updateCartCount() {
    fetch('/cart.js')
      .then(function (r) { return r.json(); })
      .then(function (cart) {
        var badges = document.querySelectorAll('[data-cart-count], .cart-count, .cart__count, .header__cart-count');
        badges.forEach(function (el) { el.textContent = cart.item_count; });
      })
      .catch(function () {});
  }

  /* ── Toast notification ──────────────────────────────────── */
  function showToast(msg) {
    var existing = document.querySelector('.cpg-toast');
    if (existing) existing.remove();
    var toast = document.createElement('div');
    toast.className = 'cpg-toast';
    toast.textContent = msg;
    document.body.appendChild(toast);
    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        toast.classList.add('cpg-toast--show');
      });
    });
    setTimeout(function () {
      toast.classList.remove('cpg-toast--show');
      setTimeout(function () { toast.remove(); }, 400);
    }, 3000);
  }

  /* ── Helpers ────────────────────────────────────────────── */
  function escapeHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function formatMoney(cents) {
    return (cents / 100).toLocaleString('en-US', { style: 'currency', currency: '{{ shop.currency }}' });
  }

  /* ── Bind Quick View buttons ────────────────────────────── */
  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.cpg-card__quick-view');
    if (!btn) return;
    e.preventDefault();
    var handle = btn.getAttribute('data-product-handle');
    if (handle) loadProduct(handle);
  });

})();
</script>

{% schema %}
{
  "name": "Custom Product Grid",
  "tag": "section",
  "class": "cpg-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Tisso vision in the wild"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Product Grid",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ],
  "max_blocks": 6
}
{% endschema %}

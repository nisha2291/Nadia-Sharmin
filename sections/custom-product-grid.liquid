<section class="cpg-section" id="cpg-{{ section.id }}">
  <div class="cpg-container">
    {% if section.settings.heading != blank %}
      <h2 class="cpg-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="cpg-grid">
      {% for block in section.blocks %}
        {% assign product = block.settings.product %}
        {% if product != blank %}
          <div class="cpg-card" {{ block.shopify_attributes }}>
            <div class="cpg-card__image-wrap">
              {% if product.featured_image %}
                <img
                  class="cpg-card__image"
                  src="{{ product.featured_image | image_url: width: 900 }}"
                  alt="{{ product.featured_image.alt | default: product.title | escape }}"
                  loading="lazy"
                  width="600"
                  height="720"
                >
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'cpg-placeholder-svg' }}
              {% endif %}

              <button
                class="cpg-card__quick-view"
                data-product-handle="{{ product.handle }}"
                aria-label="Quick view {{ product.title | escape }}"
                type="button"
              >+</button>
            </div>
          </div>
        {% else %}
          <div class="cpg-card cpg-card--empty" {{ block.shopify_attributes }}>
            <div class="cpg-card__image-wrap">
              {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'cpg-placeholder-svg' }}
              <span class="cpg-card__empty-label">Select a product in customizer</span>
            </div>
          </div>
        {% endif %}
      {% endfor %}

      {% if section.blocks.size == 0 %}
        {% for i in (1..6) %}
          <div class="cpg-card cpg-card--empty">
            <div class="cpg-card__image-wrap">
              {{ 'product-' | append: i | placeholder_svg_tag: 'cpg-placeholder-svg' }}
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

<div class="cpg-modal" id="cpg-modal" role="dialog" aria-modal="true" hidden>
  <div class="cpg-modal__backdrop" id="cpg-modal-backdrop"></div>

  <div class="cpg-modal__panel">
    <button class="cpg-modal__close" id="cpg-modal-close" aria-label="Close" type="button">&#x2715;</button>

    <div id="cpg-modal-body">
      <div class="cpg-loading">
        <div class="cpg-spinner"></div>
      </div>
    </div>
  </div>
</div>

<div class="cpg-toast" id="cpg-toast"></div>

<style>
.cpg-section *,
.cpg-modal * {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  font-family: inherit;
}

.cpg-section {
  padding: 56px 0 72px;
  background: #efefef;
}

.cpg-container {
  max-width: 1312px;
  margin: 0 auto;
  padding: 0 48px;
}

.cpg-heading {
  font-size: 28px;
  line-height: 1.2;
  font-weight: 400;
  color: #1a1a1a;
  margin-bottom: 24px;
}

.cpg-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  column-gap: 16px;
  row-gap: 16px;
}

.cpg-card {
  position: relative;
  background: transparent;
  overflow: hidden;
  cursor: pointer;
}

.cpg-card--empty {
  cursor: default;
}

.cpg-card__image-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 0.82;
  overflow: hidden;
  background: #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cpg-card__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.35s ease;
}

.cpg-card:hover .cpg-card__image {
  transform: scale(1.03);
}

.cpg-placeholder-svg {
  width: 100%;
  height: 100%;
  background: #ececec;
}

.cpg-card__empty-label {
  position: absolute;
  bottom: 10px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 11px;
  color: #888;
  white-space: nowrap;
  background: rgba(255,255,255,0.88);
  padding: 3px 10px;
  border-radius: 2px;
}

.cpg-card__quick-view {
  position: absolute;
  top: 50%;
  right: 12px;
  transform: translateY(-50%);
  width: 28px;
  height: 28px;
  border: none;
  border-radius: 50%;
  background: rgba(255,255,255,0.96);
  color: #111;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  font-weight: 400;
  line-height: 1;
  cursor: pointer;
  box-shadow: 0 3px 10px rgba(0,0,0,0.12);
  transition: transform 0.2s ease, background 0.2s ease, color 0.2s ease;
  z-index: 2;
}

.cpg-card__quick-view:hover {
  background: #111;
  color: #fff;
  transform: translateY(-50%) scale(1.06);
}

.cpg-modal {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cpg-modal[hidden] {
  display: none;
}

.cpg-modal__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.34);
  cursor: pointer;
}

.cpg-modal__panel {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 400px;
  background: #f4f4f4;
  padding: 20px;
  max-height: 92vh;
  overflow-y: auto;
  animation: cpgUp 0.22s ease;
}

@keyframes cpgUp {
  from {
    opacity: 0;
    transform: translateY(14px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.cpg-modal__close {
  position: absolute;
  top: 12px;
  right: 14px;
  background: none;
  border: none;
  font-size: 22px;
  line-height: 1;
  color: #111;
  cursor: pointer;
  padding: 2px;
}

.cpg-modal__close:hover {
  opacity: 0.7;
}

.cpg-card-top {
  display: grid;
  grid-template-columns: 112px 1fr;
  gap: 14px;
  align-items: start;
  margin-bottom: 18px;
}

.cpg-card-top__img,
.cpg-card-top__img-placeholder {
  width: 112px;
  height: 112px;
  object-fit: cover;
  display: block;
  background: #e9e9e9;
}

.cpg-card-top__info {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.cpg-card-top__title {
  font-size: 18px;
  line-height: 1.15;
  font-weight: 400;
  color: #1a1a1a;
}

.cpg-card-top__price {
  font-size: 18px;
  line-height: 1.2;
  color: #111;
  font-weight: 400;
}

.cpg-card-top__desc {
  font-size: 13px;
  line-height: 1.35;
  color: #444;
  margin-top: 2px;
}

.cpg-opt {
  margin-bottom: 16px;
}

.cpg-opt__name {
  display: block;
  font-size: 13px;
  line-height: 1.2;
  font-weight: 400;
  color: #222;
  margin-bottom: 8px;
}

.cpg-swatches {
  display: flex;
  width: 100%;
}

.cpg-swatch {
  flex: 1;
  min-height: 46px;
  padding: 0 12px;
  border: 1px solid #a9a9a9;
  border-right: none;
  background: #fff;
  color: #111;
  font-size: 13px;
  font-weight: 400;
  cursor: pointer;
  text-align: left;
  transition: background 0.15s ease, color 0.15s ease;
}

.cpg-swatch:last-child {
  border-right: 1px solid #a9a9a9;
}

.cpg-swatch.is-active {
  box-shadow: inset 4px 0 0 #1d4ed8;
}

.cpg-swatch:hover:not(.is-active) {
  background: #f8f8f8;
}

.cpg-size-wrap {
  position: relative;
}

.cpg-size-select {
  width: 100%;
  min-height: 46px;
  padding: 0 48px 0 14px;
  border: 1px solid #a9a9a9;
  background: #fff;
  color: #222;
  font-size: 13px;
  appearance: none;
  border-radius: 0;
  cursor: pointer;
}

.cpg-size-select:focus {
  outline: none;
  border-color: #777;
}

.cpg-size-chevron {
  position: absolute;
  right: 16px;
  top: 50%;
  transform: translateY(-50%);
  color: #333;
  font-size: 15px;
  pointer-events: none;
}

.cpg-atc-btn {
  width: 100%;
  min-height: 56px;
  padding: 0 18px;
  border: none;
  background: #000;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 28px;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  cursor: pointer;
  margin-top: 18px;
  transition: background 0.18s ease;
}

.cpg-atc-btn:hover {
  background: #1d1d1d;
}

.cpg-atc-btn:disabled {
  background: #8f8f8f;
  cursor: not-allowed;
}

.cpg-atc-btn__arrow {
  font-size: 22px;
  line-height: 1;
  font-weight: 300;
}

.cpg-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 180px;
}

.cpg-spinner {
  width: 30px;
  height: 30px;
  border: 3px solid #eee;
  border-top-color: #333;
  border-radius: 50%;
  animation: cpgSpin 0.65s linear infinite;
}

@keyframes cpgSpin {
  to { transform: rotate(360deg); }
}

.cpg-toast {
  position: fixed;
  left: 50%;
  bottom: 24px;
  transform: translateX(-50%) translateY(60px);
  background: #111;
  color: #fff;
  padding: 11px 24px;
  font-size: 13px;
  font-weight: 500;
  white-space: nowrap;
  z-index: 99999;
  pointer-events: none;
  transition: transform 0.25s ease;
}

.cpg-toast.show {
  transform: translateX(-50%) translateY(0);
}

@media (max-width: 900px) {
  .cpg-container {
    padding: 0 24px;
  }

  .cpg-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: 16px;
    row-gap: 16px;
  }
}

@media (max-width: 540px) {
  .cpg-container {
    padding: 0 16px;
  }

  .cpg-grid {
    grid-template-columns: 1fr;
    column-gap: 12px;
    row-gap: 12px;
  }

  .cpg-modal__panel {
    max-width: 94vw;
    padding: 16px;
  }

  .cpg-card-top {
    grid-template-columns: 88px 1fr;
  }

  .cpg-card-top__img,
  .cpg-card-top__img-placeholder {
    width: 88px;
    height: 88px;
  }
}
</style>

<script>
(function () {
  'use strict';

  var modal = document.getElementById('cpg-modal');
  var body = document.getElementById('cpg-modal-body');
  var closeBtn = document.getElementById('cpg-modal-close');
  var backdrop = document.getElementById('cpg-modal-backdrop');
  var toast = document.getElementById('cpg-toast');
  var toastTimer = null;
  var activeHandle = null;
  var currentProduct = null;
  var selectedOpts = {};

  function open() {
    modal.removeAttribute('hidden');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    modal.setAttribute('hidden', '');
    document.body.style.overflow = '';
    body.innerHTML = '<div class="cpg-loading"><div class="cpg-spinner"></div></div>';
    activeHandle = null;
    currentProduct = null;
    selectedOpts = {};
  }

  closeBtn.addEventListener('click', close);
  backdrop.addEventListener('click', close);
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') close();
  });

  function load(handle) {
    if (activeHandle === handle) return;
    activeHandle = handle;
    open();
    body.innerHTML = '<div class="cpg-loading"><div class="cpg-spinner"></div></div>';

    fetch('/products/' + handle + '.js')
      .then(function(r) {
        if (!r.ok) throw r.status;
        return r.json();
      })
      .then(function(p) {
        currentProduct = p;
        render(p);
      })
      .catch(function() {
        body.innerHTML = '<p style="padding:24px;text-align:center">Could not load product. <a href="/products/' + handle + '">View page &rarr;</a></p>';
      });
  }

  function render(p) {
    selectedOpts = {};

    var imgSrc = p.featured_image || (p.images && p.images[0]);
    var imgHtml = imgSrc
      ? '<img class="cpg-card-top__img" src="' + imgSrc + '" alt="' + x(p.title) + '">'
      : '<div class="cpg-card-top__img-placeholder"></div>';

    var price = money(p.price_min);
    if (p.price_min !== p.price_max) {
      price += ' – ' + money(p.price_max);
    }

    var desc = p.description
      ? p.description.replace(/<[^>]+>/g, '').substring(0, 160) + (p.description.length > 160 ? '…' : '')
      : '';

    var colorOpt = null;
    var sizeOpt = null;
    var otherOpts = [];

    if (p.options && !(p.options.length === 1 && p.options[0] === 'Title')) {
      p.options.forEach(function(o) {
        if (/colou?r/i.test(o)) colorOpt = o;
        else if (/size/i.test(o)) sizeOpt = o;
        else otherOpts.push(o);
      });
    }

    var optsHtml = '';

    if (colorOpt) {
      var colorVals = optVals(p, colorOpt);
      selectedOpts[colorOpt] = colorVals[0];

      optsHtml += '<div class="cpg-opt">';
      optsHtml += '<span class="cpg-opt__name">' + x(colorOpt) + '</span>';
      optsHtml += '<div class="cpg-swatches" data-opt="' + x(colorOpt) + '">';
      colorVals.forEach(function(v, i) {
        optsHtml += '<button class="cpg-swatch' + (i === 0 ? ' is-active' : '') + '" data-opt="' + x(colorOpt) + '" data-val="' + x(v) + '" type="button">' + x(v) + '</button>';
      });
      optsHtml += '</div></div>';
    }

    otherOpts.forEach(function(optName) {
      var vals = optVals(p, optName);
      selectedOpts[optName] = vals[0];

      optsHtml += '<div class="cpg-opt">';
      optsHtml += '<span class="cpg-opt__name">' + x(optName) + '</span>';
      optsHtml += '<div class="cpg-swatches" data-opt="' + x(optName) + '">';
      vals.forEach(function(v, i) {
        optsHtml += '<button class="cpg-swatch' + (i === 0 ? ' is-active' : '') + '" data-opt="' + x(optName) + '" data-val="' + x(v) + '" type="button">' + x(v) + '</button>';
      });
      optsHtml += '</div></div>';
    });

    if (sizeOpt) {
      var sizeVals = optVals(p, sizeOpt);

      optsHtml += '<div class="cpg-opt">';
      optsHtml += '<span class="cpg-opt__name">' + x(sizeOpt) + '</span>';
      optsHtml += '<div class="cpg-size-wrap">';
      optsHtml += '<select class="cpg-size-select" id="cpg-size-sel" data-opt="' + x(sizeOpt) + '">';
      optsHtml += '<option value="" disabled selected>Choose your size</option>';
      sizeVals.forEach(function(v) {
        optsHtml += '<option value="' + x(v) + '">' + x(v) + '</option>';
      });
      optsHtml += '</select>';
      optsHtml += '<span class="cpg-size-chevron">&#8964;</span>';
      optsHtml += '</div></div>';
    }

    var fallbackHtml = '';
    if (!colorOpt && !sizeOpt && otherOpts.length === 0 && p.variants.length > 1) {
      var varOpts = p.variants.map(function(v) {
        return '<option value="' + v.id + '"' + (v.available ? '' : ' disabled') + '>' + x(v.title) + (v.available ? '' : ' — Sold out') + '</option>';
      }).join('');
      fallbackHtml = '<div class="cpg-opt"><select class="cpg-size-select" id="cpg-var-sel">' + varOpts + '</select></div>';
      selectedOpts._variant = p.variants[0].id;
    }

    if (p.variants.length === 1) {
      selectedOpts._variant = p.variants[0].id;
    }

    body.innerHTML =
      '<div class="cpg-card-top">' +
        '<div>' + imgHtml + '</div>' +
        '<div class="cpg-card-top__info">' +
          '<p class="cpg-card-top__title">' + x(p.title) + '</p>' +
          '<p class="cpg-card-top__price">' + price + '</p>' +
          (desc ? '<p class="cpg-card-top__desc">' + desc + '</p>' : '') +
        '</div>' +
      '</div>' +
      optsHtml +
      fallbackHtml +
      '<button class="cpg-atc-btn" id="cpg-atc" type="button">' +
        '<span>ADD TO CART</span>' +
        '<span class="cpg-atc-btn__arrow">&rarr;</span>' +
      '</button>';

    body.querySelectorAll('.cpg-swatch').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var opt = this.getAttribute('data-opt');
        var val = this.getAttribute('data-val');
        selectedOpts[opt] = val;

        body.querySelectorAll('.cpg-swatch[data-opt="' + opt + '"]').forEach(function(b) {
          b.classList.toggle('is-active', b.getAttribute('data-val') === val);
        });
      });
    });

    var ssel = document.getElementById('cpg-size-sel');
    if (ssel) {
      ssel.addEventListener('change', function() {
        selectedOpts[this.getAttribute('data-opt')] = this.value;
      });
    }

    var vsel = document.getElementById('cpg-var-sel');
    if (vsel) {
      vsel.addEventListener('change', function() {
        selectedOpts._variant = this.value;
      });
    }

    document.getElementById('cpg-atc').addEventListener('click', function() {
      var vid = resolveVariant(p);
      if (!vid) {
        showToast('Please select your size.');
        return;
      }
      atc(vid, this);
    });
  }

  function resolveVariant(p) {
    if (selectedOpts._variant) return selectedOpts._variant;
    if (p.variants.length === 1) return p.variants[0].id;

    var match = null;

    p.variants.forEach(function(v) {
      if (match) return;

      var ok = p.options.every(function(opt, i) {
        var chosen = selectedOpts[opt];
        if (!chosen) return true;
        return v['option' + (i + 1)] === chosen;
      });

      if (ok && v.available) match = v.id;
    });

    if (!match) {
      p.variants.forEach(function(v) {
        if (match) return;

        var ok = p.options.every(function(opt, i) {
          var chosen = selectedOpts[opt];
          if (!chosen) return true;
          return v['option' + (i + 1)] === chosen;
        });

        if (ok) match = v.id;
      });
    }

    return match;
  }

  function atc(vid, btn) {
    btn.disabled = true;
    btn.querySelector('span').textContent = 'Adding…';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: parseInt(vid, 10), quantity: 1 })
    })
      .then(function(r) {
        if (!r.ok) throw r;
        return r.json();
      })
      .then(function() {
        btn.querySelector('span').textContent = '✓ Added!';
        showToast('Added to cart ✓');
        refreshCount();

        setTimeout(function() {
          btn.disabled = false;
          btn.innerHTML = '<span>ADD TO CART</span><span class="cpg-atc-btn__arrow">&rarr;</span>';
        }, 2000);
      })
      .catch(function() {
        btn.disabled = false;
        btn.innerHTML = '<span>ADD TO CART</span><span class="cpg-atc-btn__arrow">&rarr;</span>';
        showToast('Error — please try again.');
      });
  }

  function refreshCount() {
    fetch('/cart.js')
      .then(function(r) { return r.json(); })
      .then(function(c) {
        document.querySelectorAll('[data-cart-count], .cart-count, .cart__count, .header__cart-count').forEach(function(el) {
          el.textContent = c.item_count;
        });
      })
      .catch(function() {});
  }

  function showToast(msg) {
    toast.textContent = msg;
    toast.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(function() {
      toast.classList.remove('show');
    }, 2600);
  }

  function x(s) {
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function money(cents) {
    return (cents / 100).toLocaleString('en-US', {
      style: 'currency',
      currency: '{{ shop.currency }}'
    });
  }

  function optVals(p, optName) {
    var idx = p.options.indexOf(optName);
    var seen = {};
    var vals = [];

    p.variants.forEach(function(v) {
      var val = v['option' + (idx + 1)];
      if (val && !seen[val]) {
        seen[val] = true;
        vals.push(val);
      }
    });

    return vals;
  }

  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.cpg-card__quick-view');
    if (!btn) return;

    e.preventDefault();
    var h = btn.getAttribute('data-product-handle');
    if (h) load(h);
  });
})();
</script>

{% schema %}
{
  "name": "Custom Product Grid",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Tisso vision in the wild"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Product Grid",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ],
  "max_blocks": 6
}
{% endschema %}
<section class="cpg-section" id="cpg-{{ section.id }}">
  <div class="cpg-container">
    {% if section.settings.heading != blank %}
      <h2 class="cpg-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    <div class="cpg-grid">
      {% for block in section.blocks %}
        {% assign product = block.settings.product %}
        {% if product != blank %}
          <div class="cpg-card" {{ block.shopify_attributes }}>
            <div class="cpg-card__image-wrap">
              {% if product.featured_image %}
                <img
                  class="cpg-card__image"
                  src="{{ product.featured_image | image_url: width: 700 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  loading="lazy"
                >
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'cpg-placeholder-svg' }}
              {% endif %}
              <button
                class="cpg-card__quick-view"
                data-product-handle="{{ product.handle }}"
                aria-label="Quick view {{ product.title | escape }}"
              >+ Quick View</button>
            </div>
          </div>
        {% else %}
          <div class="cpg-card cpg-card--empty" {{ block.shopify_attributes }}>
            <div class="cpg-card__image-wrap">
              {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'cpg-placeholder-svg' }}
              <span class="cpg-card__empty-label">Select a product in customizer</span>
            </div>
          </div>
        {% endif %}
      {% endfor %}
      {% if section.blocks.size == 0 %}
        {% for i in (1..6) %}
          <div class="cpg-card cpg-card--empty">
            <div class="cpg-card__image-wrap">
              {{ 'product-' | append: i | placeholder_svg_tag: 'cpg-placeholder-svg' }}
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

<!-- Modal -->
<div class="cpg-modal" id="cpg-modal" role="dialog" aria-modal="true" hidden>
  <div class="cpg-modal__backdrop" id="cpg-modal-backdrop"></div>
  <div class="cpg-modal__panel">
    <button class="cpg-modal__close" id="cpg-modal-close" aria-label="Close">&#x2715;</button>
    <div id="cpg-modal-body">
      <div class="cpg-loading"><div class="cpg-spinner"></div></div>
    </div>
  </div>
</div>

<div class="cpg-toast" id="cpg-toast"></div>

<style>
/* ── Reset ───────────────────────────────────────────────── */
.cpg-section *, .cpg-modal * {
  box-sizing: border-box;
  margin: 0; padding: 0;
  font-family: inherit;
}

/* ── Section & Grid ──────────────────────────────────────── */
.cpg-section { padding: 48px 0 64px; background: #fff; }
.cpg-container { max-width: 1337px; margin: 0 auto; padding: 0 20px; }
.cpg-heading {
  font-size: clamp(1.2rem, 2.5vw, 1.7rem);
  font-weight: 500; margin-bottom: 24px; color: #111;
}
.cpg-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30px;
}
@media (max-width: 900px) { .cpg-grid { grid-template-columns: repeat(2,1fr); } }
@media (max-width: 540px) { .cpg-grid { grid-template-columns: 1fr; gap: 16px; } }

/* ── Card ────────────────────────────────────────────────── */
.cpg-card { position: relative; overflow: hidden; background: #f3f3f3; cursor: pointer; }
.cpg-card--empty { cursor: default; }
.cpg-card__image-wrap {
  position: relative; width: 100%;
  aspect-ratio: 1 / 1.07; overflow: hidden;
  display: flex; align-items: center; justify-content: center;
}
.cpg-card__image { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.5s ease; }
.cpg-card:hover .cpg-card__image { transform: scale(1.05); }
.cpg-placeholder-svg { width: 100%; height: 100%; background: #ececec; }
.cpg-card__empty-label {
  position: absolute; bottom: 10px; left: 50%; transform: translateX(-50%);
  font-size: 11px; color: #888; white-space: nowrap;
  background: rgba(255,255,255,0.85); padding: 3px 10px; border-radius: 2px;
}
.cpg-card__quick-view {
  position: absolute; bottom: 14px; left: 50%;
  transform: translateX(-50%) translateY(12px); opacity: 0;
  white-space: nowrap; padding: 10px 22px;
  background: rgba(255,255,255,0.96); border: none; border-radius: 2px;
  font-size: 11px; font-weight: 700; letter-spacing: 0.09em; text-transform: uppercase;
  cursor: pointer; transition: opacity 0.22s ease, transform 0.22s ease;
}
.cpg-card:hover .cpg-card__quick-view { opacity: 1; transform: translateX(-50%) translateY(0); }

/* ── Modal shell ─────────────────────────────────────────── */
.cpg-modal {
  position: fixed; inset: 0; z-index: 9999;
  display: flex; align-items: center; justify-content: center;
}
.cpg-modal[hidden] { display: none; }
.cpg-modal__backdrop { position: absolute; inset: 0; background: rgba(0,0,0,0.4); cursor: pointer; }
.cpg-modal__panel {
  position: relative; background: #fff;
  width: min(560px, 95vw);
  max-height: 94vh; overflow-y: auto;
  padding: 20px;
  z-index: 1;
  animation: cpgUp 0.22s ease;
}
@keyframes cpgUp { from { opacity:0; transform:translateY(16px); } to { opacity:1; transform:translateY(0); } }
.cpg-modal__close {
  position: absolute; top: 10px; right: 12px;
  background: none; border: none; font-size: 16px;
  cursor: pointer; color: #999; padding: 4px 6px; line-height: 1;
}
.cpg-modal__close:hover { color: #000; }

/* ── Card component — matches Figma exactly ──────────────── */
/*
  Layout:
  ┌──────────────────────────────────────────┐
  │ [img 80px] Title                         │
  │            980,00€                       │
  │            Description text...           │
  ├──────────────────────────────────────────┤
  │ Color                                    │
  │ [  Blue  ][  Black  ]                    │
  ├──────────────────────────────────────────┤
  │ Size                                     │
  │ [ Choose your size              ∨ ]      │
  ├──────────────────────────────────────────┤
  │ [     ADD TO CART          →    ]        │
  └──────────────────────────────────────────┘
*/
.cpg-card-top {
  display: grid;
  grid-template-columns: 80px 1fr;
  gap: 14px;
  margin-bottom: 16px;
}
.cpg-card-top__img {
  width: 80px; height: 80px;
  object-fit: cover; display: block;
  flex-shrink: 0;
}
.cpg-card-top__img-placeholder {
  width: 80px; height: 80px;
  background: #eee; flex-shrink: 0;
}
.cpg-card-top__info { display: flex; flex-direction: column; gap: 4px; }
.cpg-card-top__title { font-size: 15px; font-weight: 500; color: #111; line-height: 1.3; }
.cpg-card-top__price { font-size: 15px; color: #111; font-weight: 400; }
.cpg-card-top__desc  { font-size: 12.5px; line-height: 1.6; color: #666; margin-top: 4px; }

/* Option group */
.cpg-opt { margin-bottom: 14px; }
.cpg-opt__name {
  font-size: 12.5px; font-weight: 400; color: #333;
  margin-bottom: 7px; display: block;
}

/* Color swatches — side by side bordered boxes like Figma */
.cpg-swatches {
  display: flex;
  border: 1px solid #d0d0d0;
}
.cpg-swatch {
  flex: 1;
  padding: 11px 8px;
  border: none;
  border-right: 1px solid #d0d0d0;
  background: #fff;
  font-size: 13px; color: #111;
  cursor: pointer; text-align: center;
  transition: background 0.12s;
  position: relative;
}
.cpg-swatch:last-child { border-right: none; }
.cpg-swatch.is-active {
  background: #fff;
  border-bottom: 3px solid #1a56db;
  padding-bottom: 8px;
}
.cpg-swatch:hover:not(.is-active) { background: #f5f5f5; }

/* Size dropdown — Figma style */
.cpg-size-wrap { position: relative; }
.cpg-size-select {
  width: 100%;
  padding: 12px 40px 12px 14px;
  border: 1px solid #d0d0d0;
  background: #fff;
  font-size: 13px; color: #333;
  cursor: pointer; appearance: none;
  border-radius: 0;
}
.cpg-size-select:focus { outline: 1px solid #888; }
.cpg-size-chevron {
  position: absolute; right: 14px; top: 50%;
  transform: translateY(-50%);
  pointer-events: none; color: #555; font-size: 13px;
}

/* ADD TO CART button */
.cpg-atc-btn {
  display: flex; align-items: center; justify-content: space-between;
  width: 100%; padding: 15px 20px;
  background: #111; color: #fff; border: none;
  font-size: 12.5px; font-weight: 700;
  letter-spacing: 0.1em; text-transform: uppercase;
  cursor: pointer; transition: background 0.18s;
  margin-top: 16px;
}
.cpg-atc-btn:hover { background: #333; }
.cpg-atc-btn:disabled { background: #999; cursor: not-allowed; }
.cpg-atc-btn__arrow { font-size: 18px; font-weight: 300; }

/* Loading */
.cpg-loading { display: flex; align-items: center; justify-content: center; min-height: 180px; }
.cpg-spinner {
  width: 30px; height: 30px;
  border: 3px solid #eee; border-top-color: #333;
  border-radius: 50%; animation: cpgSpin 0.65s linear infinite;
}
@keyframes cpgSpin { to { transform: rotate(360deg); } }

/* Toast */
.cpg-toast {
  position: fixed; bottom: 24px; left: 50%;
  transform: translateX(-50%) translateY(60px);
  background: #111; color: #fff;
  padding: 11px 24px; font-size: 13px; font-weight: 500;
  z-index: 99999; pointer-events: none; white-space: nowrap;
  transition: transform 0.25s ease;
}
.cpg-toast.show { transform: translateX(-50%) translateY(0); }
</style>

<script>
(function () {
  'use strict';

  var modal      = document.getElementById('cpg-modal');
  var body       = document.getElementById('cpg-modal-body');
  var closeBtn   = document.getElementById('cpg-modal-close');
  var backdrop   = document.getElementById('cpg-modal-backdrop');
  var toast      = document.getElementById('cpg-toast');
  var toastTimer = null;
  var activeHandle    = null;
  var currentProduct  = null;
  var selectedOpts    = {};

  /* ── open / close ────────────────────────────────────── */
  function open()  { modal.removeAttribute('hidden'); document.body.style.overflow = 'hidden'; }
  function close() {
    modal.setAttribute('hidden', '');
    document.body.style.overflow = '';
    body.innerHTML = '<div class="cpg-loading"><div class="cpg-spinner"></div></div>';
    activeHandle = null; currentProduct = null; selectedOpts = {};
  }
  closeBtn.addEventListener('click', close);
  backdrop.addEventListener('click', close);
  document.addEventListener('keydown', function(e){ if(e.key==='Escape') close(); });

  /* ── fetch ───────────────────────────────────────────── */
  function load(handle) {
    if (activeHandle === handle) return;
    activeHandle = handle;
    open();
    body.innerHTML = '<div class="cpg-loading"><div class="cpg-spinner"></div></div>';
    fetch('/products/' + handle + '.js')
      .then(function(r){ if(!r.ok) throw r.status; return r.json(); })
      .then(function(p){ currentProduct = p; render(p); })
      .catch(function(){
        body.innerHTML = '<p style="padding:24px;text-align:center">Could not load product. <a href="/products/'+handle+'">View page &rarr;</a></p>';
      });
  }

  /* ── render ──────────────────────────────────────────── */
  function render(p) {
    var imgSrc = p.featured_image || (p.images && p.images[0]);
    var imgHtml = imgSrc
      ? '<img class="cpg-card-top__img" src="'+imgSrc+'" alt="'+x(p.title)+'">'
      : '<div class="cpg-card-top__img-placeholder"></div>';

    var price = money(p.price_min);
    if (p.price_min !== p.price_max) price += ' &ndash; ' + money(p.price_max);

    var desc = p.description
      ? p.description.replace(/<[^>]+>/g,'').substring(0,160) + (p.description.length>160?'\u2026':'')
      : '';

    /* detect option types */
    var colorOpt = null, sizeOpt = null, otherOpts = [];
    if (p.options && !(p.options.length===1 && p.options[0]==='Title')) {
      p.options.forEach(function(o) {
        if (/colou?r/i.test(o))      colorOpt = o;
        else if (/size/i.test(o))    sizeOpt  = o;
        else                         otherOpts.push(o);
      });
    }

    var optsHtml = '';

    /* Color block */
    if (colorOpt) {
      var colorVals = optVals(p, colorOpt);
      selectedOpts[colorOpt] = colorVals[0];
      optsHtml += '<div class="cpg-opt">';
      optsHtml += '<span class="cpg-opt__name">'+x(colorOpt)+'</span>';
      optsHtml += '<div class="cpg-swatches" data-opt="'+x(colorOpt)+'">';
      colorVals.forEach(function(v, i) {
        optsHtml += '<button class="cpg-swatch'+(i===0?' is-active':'')+'" data-opt="'+x(colorOpt)+'" data-val="'+x(v)+'">'+x(v)+'</button>';
      });
      optsHtml += '</div></div>';
    }

    /* Other non-size options as swatches */
    otherOpts.forEach(function(optName) {
      var vals = optVals(p, optName);
      selectedOpts[optName] = vals[0];
      optsHtml += '<div class="cpg-opt">';
      optsHtml += '<span class="cpg-opt__name">'+x(optName)+'</span>';
      optsHtml += '<div class="cpg-swatches" data-opt="'+x(optName)+'">';
      vals.forEach(function(v, i) {
        optsHtml += '<button class="cpg-swatch'+(i===0?' is-active':'')+'" data-opt="'+x(optName)+'" data-val="'+x(v)+'">'+x(v)+'</button>';
      });
      optsHtml += '</div></div>';
    });

    /* Size block */
    if (sizeOpt) {
      var sizeVals = optVals(p, sizeOpt);
      optsHtml += '<div class="cpg-opt">';
      optsHtml += '<span class="cpg-opt__name">'+x(sizeOpt)+'</span>';
      optsHtml += '<div class="cpg-size-wrap">';
      optsHtml += '<select class="cpg-size-select" id="cpg-size-sel" data-opt="'+x(sizeOpt)+'">';
      optsHtml += '<option value="" disabled selected>Choose your size</option>';
      sizeVals.forEach(function(v){
        optsHtml += '<option value="'+x(v)+'">'+x(v)+'</option>';
      });
      optsHtml += '</select>';
      optsHtml += '<span class="cpg-size-chevron">&#8964;</span>';
      optsHtml += '</div></div>';
    }

    /* Fallback: flat variant dropdown if no named options */
    var fallbackHtml = '';
    if (!colorOpt && !sizeOpt && otherOpts.length === 0 && p.variants.length > 1) {
      var varOpts = p.variants.map(function(v){
        return '<option value="'+v.id+'"'+(v.available?'':' disabled')+'>'+x(v.title)+(v.available?'':' — Sold out')+'</option>';
      }).join('');
      fallbackHtml = '<div class="cpg-opt"><select class="cpg-size-select" id="cpg-var-sel">'+varOpts+'</select></div>';
      selectedOpts['_variant'] = p.variants[0].id;
    }
    if (p.variants.length === 1) {
      selectedOpts['_variant'] = p.variants[0].id;
    }

    body.innerHTML =
      '<div class="cpg-card-top">'
        + '<div>'+imgHtml+'</div>'
        + '<div class="cpg-card-top__info">'
          + '<p class="cpg-card-top__title">'+x(p.title)+'</p>'
          + '<p class="cpg-card-top__price">'+price+'</p>'
          + (desc ? '<p class="cpg-card-top__desc">'+desc+'</p>' : '')
        + '</div>'
      + '</div>'
      + optsHtml
      + fallbackHtml
      + '<button class="cpg-atc-btn" id="cpg-atc">'
        + '<span>ADD TO CART</span>'
        + '<span class="cpg-atc-btn__arrow">&rarr;</span>'
      + '</button>';

    /* swatch clicks */
    body.querySelectorAll('.cpg-swatch').forEach(function(btn){
      btn.addEventListener('click', function(){
        var opt = this.getAttribute('data-opt');
        var val = this.getAttribute('data-val');
        selectedOpts[opt] = val;
        body.querySelectorAll('.cpg-swatch[data-opt="'+opt+'"]').forEach(function(b){
          b.classList.toggle('is-active', b.getAttribute('data-val')===val);
        });
      });
    });

    /* size select */
    var ssel = document.getElementById('cpg-size-sel');
    if (ssel) ssel.addEventListener('change', function(){
      selectedOpts[this.getAttribute('data-opt')] = this.value;
    });

    /* variant fallback select */
    var vsel = document.getElementById('cpg-var-sel');
    if (vsel) vsel.addEventListener('change', function(){
      selectedOpts['_variant'] = this.value;
    });

    /* ATC */
    document.getElementById('cpg-atc').addEventListener('click', function(){
      var vid = resolveVariant(p);
      if (!vid) { showToast('Please select your size.'); return; }
      atc(vid, this);
    });
  }

  /* ── resolve variant from selected options ───────────── */
  function resolveVariant(p) {
    if (selectedOpts['_variant']) return selectedOpts['_variant'];
    if (p.variants.length === 1)  return p.variants[0].id;
    var match = null;
    p.variants.forEach(function(v) {
      if (match) return;
      var ok = p.options.every(function(opt, i) {
        var chosen = selectedOpts[opt];
        if (!chosen) return true;
        return v['option'+(i+1)] === chosen;
      });
      if (ok && v.available) match = v.id;
    });
    /* fallback: any variant that matches even if sold out */
    if (!match) p.variants.forEach(function(v) {
      if (match) return;
      var ok = p.options.every(function(opt, i) {
        var chosen = selectedOpts[opt];
        if (!chosen) return true;
        return v['option'+(i+1)] === chosen;
      });
      if (ok) match = v.id;
    });
    return match;
  }

  /* ── add to cart ─────────────────────────────────────── */
  function atc(vid, btn) {
    btn.disabled = true;
    btn.querySelector('span').textContent = 'Adding\u2026';
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: parseInt(vid,10), quantity: 1 })
    })
    .then(function(r){ if(!r.ok) throw r; return r.json(); })
    .then(function(){
      btn.querySelector('span').textContent = '\u2713 Added!';
      showToast('Added to cart \u2713');
      refreshCount();
      setTimeout(function(){
        btn.disabled = false;
        btn.innerHTML = '<span>ADD TO CART</span><span class="cpg-atc-btn__arrow">&rarr;</span>';
      }, 2000);
    })
    .catch(function(){
      btn.disabled = false;
      btn.innerHTML = '<span>ADD TO CART</span><span class="cpg-atc-btn__arrow">&rarr;</span>';
      showToast('Error \u2014 please try again.');
    });
  }

  function refreshCount() {
    fetch('/cart.js').then(function(r){ return r.json(); }).then(function(c){
      document.querySelectorAll('[data-cart-count],.cart-count,.cart__count,.header__cart-count').forEach(function(el){
        el.textContent = c.item_count;
      });
    }).catch(function(){});
  }

  function showToast(msg) {
    toast.textContent = msg;
    toast.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(function(){ toast.classList.remove('show'); }, 2600);
  }

  /* ── helpers ─────────────────────────────────────────── */
  function x(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
  function money(cents) {
    return (cents/100).toLocaleString('en-US',{style:'currency',currency:'{{ shop.currency }}'});
  }
  function optVals(p, optName) {
    var idx = p.options.indexOf(optName);
    var seen = {}, vals = [];
    p.variants.forEach(function(v){
      var val = v['option'+(idx+1)];
      if (val && !seen[val]) { seen[val]=true; vals.push(val); }
    });
    return vals;
  }

  /* ── delegate Quick View clicks ──────────────────────── */
  document.addEventListener('click', function(e){
    var btn = e.target.closest('.cpg-card__quick-view');
    if (!btn) return;
    e.preventDefault();
    var h = btn.getAttribute('data-product-handle');
    if (h) load(h);
  });

})();
</script>

{% schema %}
{
  "name": "Custom Product Grid",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Tisso vison in the wild"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Product Grid",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ],
  "max_blocks": 6
}
{% endschema %}
